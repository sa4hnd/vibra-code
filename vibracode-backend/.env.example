# =============================================================================
# Vibra Code Backend - Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# --- Agent Configuration ---
# Which AI agent to use for code generation
# Supported providers:
#   claude  - Anthropic Claude (default, recommended) - uses Claude Agent SDK
#   cursor  - Cursor Agent - uses Cursor's AI agent
#   gemini  - Google Gemini - uses Gemini CLI
# You can also use OpenRouter as a proxy by setting OPENROUTER_API_KEY
AGENT_TYPE=claude

# --- Anthropic (Claude Agent) ---
# Required if AGENT_TYPE=claude
ANTHROPIC_API_KEY=
# API key used inside E2B sandboxes (can be the same as above)
ANTHROPIC_SANDBOX_API_KEY=
# Base URL for the Anthropic API (default: https://api.anthropic.com)
ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Cursor Agent (optional) ---
# Required only if AGENT_TYPE=cursor
CURSOR_AGENT_API_KEY=

# --- Gemini Agent (optional) ---
# Required only if AGENT_TYPE=gemini
GEMINI_API_KEY=

# --- OpenAI (optional - image generation) ---
OPENAI_API_KEY=
OPENAI_PROXY_URL=https://api.openai.com
# OpenRouter can be used as an alternative LLM proxy (https://openrouter.ai)
OPENROUTER_API_KEY=

# --- ElevenLabs (optional - audio generation) ---
ELEVENLABS_API_KEY=
ELEVENLABS_PROXY_URL=https://api.elevenlabs.io

# --- Context7 MCP (optional - documentation lookup) ---
CONTEXT7_API_KEY=

# --- E2B Sandbox ---
# Required - cloud sandbox for code execution
# Sign up at https://e2b.dev
E2B_API_KEY=
# Auto-pause sandbox after inactivity (milliseconds, default: 10 minutes)
AUTO_PAUSE_TIMEOUT_MS=600000

# --- Convex Real-time Database ---
# Required - sign up at https://convex.dev
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
# OAuth (optional - for Convex auth integration)
CONVEX_OAUTH_CLIENT_ID=
CONVEX_OAUTH_CLIENT_SECRET=
NEXT_PUBLIC_CONVEX_OAUTH_CLIENT_ID=

# --- Clerk Authentication ---
# Required - sign up at https://clerk.com
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- NextAuth (optional - web auth) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- GitHub OAuth (optional - push to GitHub feature) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Stripe Payments (optional - web subscriptions) ---
# Only needed if you want web payment processing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_WEEKLY_PLUS=

# --- RevenueCat (optional - mobile in-app purchases) ---
# Only needed if you want mobile subscription support
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_OAUTH_CLIENT_ID=
REVENUECAT_OAUTH_CLIENT_SECRET=
REVENUECAT_OAUTH_REDIRECT_URI=

# --- Northflank (optional - alternative sandbox provider) ---
NORTHFLANK_API_KEY=
NORTHFLANK_PROJECT_ID=your-project-id
SANDBOX_PROVIDER=northflank

# --- Featurebase (optional - feature request tracking) ---
FEATUREBASE_SECRET_KEY=

# --- Firecrawl (optional - web scraping) ---
FIRECRAWL_API_KEY=

# --- App Configuration ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
# Set to true when running Inngest dev server locally
# Start Inngest dev server with: npx inngest-cli@latest dev (runs on port 8288)
# Dashboard available at: http://localhost:8288
INNGEST_DEV=true

# --- Push Notifications (optional) ---
ADMIN_SECRET=
