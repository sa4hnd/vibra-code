{
  "cli": {
    "version": ">= 0.52.0",
    "requireCommit": true,
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "base": {
      "node": "22.17.1",
      "credentialsSource": "local",
      "android": {
        "image": "sdk-54",
        "resourceClass": "medium",
        "env": {
          "EAS_BUILD_PLATFORM": "android",
          "EAS_DANGEROUS_OVERRIDE_ANDROID_APPLICATION_ID": "com.yourcompany.vibracode",
          "EXPO_ROOT_DIR": "/home/expo/workingdir/build",
          "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
        }
      },
      "ios": {
        "image": "sdk-54", 
        "cocoapods": "1.16.2",
        "resourceClass": "medium",
        "env": {
          "EAS_BUILD_PLATFORM": "ios",
          "EXPO_ROOT_DIR": "/Users/expo/workingdir/build", 
          "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
        }
      }
    },
    "development": {
      "extends": "base",
      "android": {
        "gradleCommand": ":app:assembleMobileDebug",
        "withoutCredentials": true
      },
      "ios": {
        "scheme": "Vibra Code",
        "simulator": true,
        "buildConfiguration": "Debug"
      }
    },
    "release": {
      "extends": "base",
      "android": {
        "autoIncrement": "versionCode",
        "gradleCommand": ":app:bundleMobileRelease"
      },
      "ios": {
        "autoIncrement": "buildNumber",
        "scheme": "Vibra Code", 
        "buildConfiguration": "Release"
      }
    }
  },
  "submit": {
    "release": {
      "ios": {
        "ascApiKeyPath": "./credentials/AuthKey-YOUR_KEY_ID.p8",
        "ascApiKeyId": "YOUR_KEY_ID",
        "ascApiKeyIssuerId": "YOUR_ISSUER_ID",
        "ascAppId": "YOUR_APP_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./credentials/play-console-service-account.json",
        "track": "production"
      }
    }
  }
}
