# =============================================================================
# Vibra Code Mobile App - Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Clerk Authentication ---
# Required - must match your backend Clerk app
# Get your publishable key from https://dashboard.clerk.com/
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- Convex Real-time Database ---
# Required - must match your backend Convex deployment
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_OAUTH_CLIENT_ID=
EXPO_PUBLIC_PROVISION_HOST=https://api.convex.dev

# --- Backend API URL ---
# Required - URL of your vibracode-backend instance
# Use http://localhost:3000 for local development
EXPO_PUBLIC_V0_API_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# --- RevenueCat In-App Purchases (optional) ---
# Only needed if you want mobile subscription support
# Get these from https://app.revenuecat.com/
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# --- Agent Configuration ---
# Default AI agent type (claude, cursor, or gemini)
DEFAULT_AGENT_TYPE=claude

# --- Self-hosted Convex (optional) ---
# Uncomment if using a self-hosted Convex deployment
# CONVEX_SELF_HOSTED_URL=
# CONVEX_SELF_HOSTED_ADMIN_KEY=
